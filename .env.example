# App
PORT=3000
NODE_ENV=development
APP_TIMEZONE=Europe/Rome
REMINDER_CRON="0 8 * * *"
DEFAULT_REMINDER_MESSAGE_TEMPLATE="Ciao {{nome}}, ti ricordiamo la prenotazione del {{data}} alle {{ora}}. Per modifiche contattaci."
USE_FALLBACK_CHANNELS=true
DRY_RUN_NOTIFICATIONS=true

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reminders?schema=public"

# Redis / BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379

# Twilio SMS / WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
TWILIO_STATUS_CALLBACK_URL=

# Se usi Twilio Content Template Builder per WhatsApp Business initiated messages
TWILIO_WHATSAPP_CONTENT_SID=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

